{
  "name": "oauth-init",
  "version": "0.4.0",
  "description": "CLI for setting up OAuth providers for your project",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "oauth-init": "dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "dev": "bun ./src/index.ts --watch",
    "prepare": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@types/bun": "^1.3.9",
    "chalk": "^5.3.0",
    "execa": "^9.6.1",
    "inquirer": "^9.2.12",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
