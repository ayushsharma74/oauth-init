{
  "name": "oauth-init",
  "version": "1.1.0",
  "description": "CLI for setting up OAuth providers for your project",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "oauth-init": "dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "dev": "bun ./src/index.ts --watch",
    "prepare": "bun run build",
    "test": "bun test",
    "start": "node dist/index.js"
  },
  "keywords": [
    "cli",
    "oauth",
    "oauth2",
    "authentication",
    "auth",
    "google",
    "github",
    "credentials",
    "setup",
    "interactive",
    "bun",
    "typescript",
    "vercel",
    "gitlab"
  ],
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@types/bun": "^1.3.9",
    "better-auth": "^1.5.0",
    "execa": "^9.6.1",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
